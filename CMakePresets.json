{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 25, "patch": 0},
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RUNTIME_SANITIZER": "address"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RUNTIME_SANITIZER": "thread"
      }
    },
    {
      "name": "ubsan",
      "displayName": "UndefinedBehaviorSanitizer",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RUNTIME_SANITIZER": "undefined"
      }
    },
    {
      "name": "avx512",
      "displayName": "AVX-512 Release (Linux only — requires AVX-512 capable CPU)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RUNTIME_AVX512": "ON"
      }
    }
  ],
  "buildPresets": [
    {"name": "debug",   "configurePreset": "debug"},
    {"name": "release", "configurePreset": "release"},
    {"name": "asan",    "configurePreset": "asan"},
    {"name": "tsan",    "configurePreset": "tsan"},
    {"name": "ubsan",   "configurePreset": "ubsan"},
    {"name": "avx512",  "configurePreset": "avx512"}
  ],
  "testPresets": [
    {"name": "debug",  "configurePreset": "debug",  "output": {"outputOnFailure": true}},
    {"name": "asan",   "configurePreset": "asan",   "output": {"outputOnFailure": true}},
    {"name": "tsan",   "configurePreset": "tsan",   "output": {"outputOnFailure": true}},
    {"name": "ubsan",  "configurePreset": "ubsan",  "output": {"outputOnFailure": true}},
    {"name": "avx512", "configurePreset": "avx512", "output": {"outputOnFailure": true}}
  ]
}
